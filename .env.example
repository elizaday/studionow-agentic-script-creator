# Optional aliases/fallbacks for related stages.
OPENAI_MODEL_PLANNING=gpt-5.4-mini
OPENAI_MODEL_WRITER=gpt-5.5

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

WORKER_POLL_INTERVAL_MS=3000
WORKER_MAX_REVISION_LOOPS=1
